# Coach Developer Tool – Backend ympäristömuuttujat
# Kopioi tämä tiedosto .env:ksi ja täytä arvot

# Tietokantayhteys (Render antaa tämän automaattisesti)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT-asetukset
JWT_SECRET=vaihda-tama-vahvaan-satunnaiseen-merkkijonoon
JWT_EXPIRES_IN=7d

# Palvelin
PORT=3000
NODE_ENV=development

# Sallitut frontendien osoitteet (pilkulla erotettuna)
ALLOWED_ORIGINS=https://zuirela.github.io,http://localhost:8080
